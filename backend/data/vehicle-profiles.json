      "regulationNotes": [
        {
          "id": "note-1",
          "modelId": "XCF-180",
          "title": "《机动车登记规定》关于改装的要求",
          "content": "根据公安部令第164号《机动车登记规定》第二十二条，有下列情形之一，在不影响安全和识别号牌的情况下，机动车所有人不需要办理变更登记：（一）增加机动车车内装饰；（二）小型、微型载客汽车加装出入口踏步件；（三）货运机动车加装防风罩、水箱、工具箱、备胎架等。除此以外的改装，均需在改装后十日内向车辆管理所申请变更登记。",
          "noteType": "national",
          "regulationCode": "公安部令第164号",
          "effectiveDate": "2022-05-01",
          "isActive": true,
          "createdAt": "2026-01-01T00:00:00.000Z",
          "updatedAt": "2026-01-01T00:00:00.000Z"
        },
        {
          "id": "note-2",
          "modelId": "XCF-180",
          "title": "《道路交通安全法》非法改装处罚条款",
          "content": "根据《中华人民共和国道路交通安全法》第一百条，驾驶拼装的机动车或者已达到报废标准的机动车上道路行驶的，公安机关交通管理部门应当予以收缴，强制报废。对驾驶前款所列机动车上道路行驶的驾驶人，处二百元以上二千元以下罚款，并吊销机动车驾驶证。",
          "noteType": "national",
          "regulationCode": "《道路交通安全法》第一百条",
          "effectiveDate": "2011-05-01",
          "isActive": true,
          "createdAt": "2026-01-01T00:00:00.000Z",
          "updatedAt": "2026-01-01T00:00:00.000Z"
        },
        {
          "id": "note-3",
          "modelId": "XCF-180",
          "title": "年检外观检查要求",
          "content": "车辆年检时，外观必须与行驶证照片一致。车身颜色、外观形状等有明显改动的，需先到车管所办理变更登记并更换行驶证照片。",
          "noteType": "industry",
          "effectiveDate": "2019-01-01",
          "isActive": true,
          "createdAt": "2026-01-01T00:00:00.000Z",
          "updatedAt": "2026-01-01T00:00:00.000Z"
        },
        {
          "id": "note-4",
          "modelId": "XCF-180",
          "title": "内部改装作业规范",
          "content": "所有改装作业必须由经过培训的技术人员进行，涉及电气系统的改装必须使用专用接线端子和绝缘处理，禁止直接破线连接。改装完成后必须进行安全检查，包括制动测试、灯光测试、紧固件扭矩检查等。",
          "noteType": "internal",
          "isActive": true,
          "createdAt": "2026-01-01T00:00:00.000Z",
          "updatedAt": "2026-01-01T00:00:00.000Z"
        }
      ],
